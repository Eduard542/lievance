body {
    font-family: Arial;
    background: #f0f0f0;
    color: #222;
    text-align: center;
}

/* menu */
ul {
    list-style: none;
    padding: 0;
}

li {
    display: inline;
    margin: 10px;
}

a {
    text-decoration: none;
    color: black;
    padding: 8px 12px;
}

a:hover {
    background: black;
    color: white;
    border-radius: 5px;
}

.selected {
    background: black;
    color: white;
    border-radius: 5px;
}

/* obrázky */
img {
    margin: 10px;
    border-radius: 8px;
}
